{
  "entities": {
    "User": {
      "title": "User",
      "description": "Resident or Admin user profile info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["resident", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Information about a reported issue",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["water", "garbage", "electricity", "infrastructure", "other"] },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Resolved"] },
        "imageUrl": { "type": "string" },
        "adminComment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "description", "category", "location", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin identifier document (document ID is the UID)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Collection of all submitted complaints"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of UIDs that have admin privileges"
    }
  }
}
